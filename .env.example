# Database (provided by Railway PostgreSQL addon)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# App
NODE_ENV=production
PORT=3000

# The public URL of the deployed frontend (used for CORS and Better Auth)
BETTER_AUTH_URL=https://your-app.up.railway.app
TRUSTED_ORIGINS=https://your-app.up.railway.app

# Better Auth secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# AI (Anthropic)
ANTHROPIC_API_KEY=

# Email (SendGrid)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=support@yourdomain.com

# Sentry (optional)
SENTRY_DSN=

# Admin seed credentials (used once to create the admin user)
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=
